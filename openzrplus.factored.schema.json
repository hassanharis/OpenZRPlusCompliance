{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://your-org/openzrplus.factored.schema.json",
  "title": "OpenZR+ Factored Dataset (base + sparse overrides)",
  "description": "Axis-factored source-of-truth form of the OpenZR+ optical specs. Each parameter is defined once as an optional base value plus sparse overrides keyed by the dimension(s) that change it (payload rate, modulation, power profile, grid). The expanded openzrplus.schema.json dataset, mode view, and routing index are all projections of this.",
  "type": "object",
  "required": ["meta", "axes", "identity", "optical_parameters", "mask_profiles", "semantic_rules"],
  "additionalProperties": true,

  "definitions": {
    "variant": {
      "description": "One value of a parameter, applicable where 'when' matches the mode. Resolution is most-specific-wins (specificity = count of non-ALL axis keys in 'when'); 'base' is the when=all variant.",
      "type": "object",
      "required": ["id", "when"],
      "properties": {
        "id":              { "type": "string", "description": "Stable id, traceable to the source numeric_param" },
        "label":           { "type": "string", "description": "Full parameter name for this variant if it differs from the parameter name" },
        "when":            { "type": "object", "description": "Axis filter (applies_to). Empty or {format:[ALL]} = base." },
        "min":             { "type": ["number", "null"] },
        "max":             { "type": ["number", "null"] },
        "typical":         { "type": ["number", "null"] },
        "unit":            { "type": "string" },
        "unit_aliases":    { "type": "array" },
        "unit_scale_to_si":{ "type": "number" },
        "severity":        { "type": "string", "enum": ["mandatory", "conditional", "recommended", "informative"] },
        "check_type":      { "type": "string" },
        "reference":       { "type": "string" },
        "aliases":         { "type": "array" },
        "footnotes":       { "type": "array" },
        "test_conditions": { "type": "object" },
        "cross_standard_refs": { "type": "array" },
        "extraction_confidence": { "type": "string" },
        "extraction_notes":{ "type": "string" }
      },
      "additionalProperties": true
    },

    "parameter": {
      "type": "object",
      "required": ["name", "category"],
      "properties": {
        "name":       { "type": "string" },
        "category":   { "type": "string", "enum": ["dwdm_link", "tx_optical", "rx_optical", "frame_budget", "dsp", "filter", "noise_mask", "spectral_mask"] },
        "unit":       { "type": "string" },
        "check_type": { "type": "string" },
        "severity":   { "type": "string" },
        "aliases":    { "type": "array" },
        "depends_on": {
          "type": "array",
          "description": "Axes whose change moves this parameter's value. [] = invariant across all modes.",
          "items": { "type": "string", "enum": ["payload_rate", "modulation", "symbol_rate", "power_profile", "grid"] }
        },
        "base":       { "$ref": "#/definitions/variant" },
        "overrides":  { "type": "array", "items": { "$ref": "#/definitions/variant" } }
      },
      "additionalProperties": true
    }
  },

  "properties": {
    "meta":  { "type": "object" },
    "axes":  { "type": "object" },
    "identity": { "type": "array" },
    "optical_parameters": {
      "type": "object",
      "additionalProperties": { "$ref": "#/definitions/parameter" }
    },
    "mask_profiles":  { "type": "object" },
    "semantic_rules": { "type": "array" }
  }
}
