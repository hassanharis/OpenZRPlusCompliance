{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://your-org/openzrplus.schema.json",
  "title": "OpenZR+ MSA Compliance Dataset",
  "description": "Structured representation of the OpenZR+ MSA Technical Specification Rev 3.0 for automated pre-qualification, compliance verification, and performance benchmarking of optical transceivers. Designed to cross-examine against OIF-400ZR, ITU-T G.709, SFF-8024, IEEE 802.3, and CMIS.",
  "type": "object",
  "required": ["$schema", "meta", "identity", "line_encoding", "framing", "optical_specs", "client_interfaces", "compliance_rules"],
  "additionalProperties": false,

  "definitions": {

    "applies_to_filter": {
      "description": "Structured scope filter. Use instead of opaque compound strings like '80HB+400ZR+'. Omit a field to mean 'all values of that dimension'.",
      "type": "object",
      "properties": {
        "format":         { "type": "array", "items": { "type": "string", "enum": ["400ZR+", "300ZR+", "200ZR+", "100ZR+", "ALL"] } },
        "symbol_rate_G":  { "type": "array", "items": { "type": "number" }, "description": "e.g. [60] or [80] or [30]" },
        "modulation":     { "type": "array", "items": { "type": "string", "enum": ["DP-16QAM", "DP-8QAM", "DP-QPSK"] } },
        "power_class":    { "type": "array", "items": { "type": "string", "enum": ["baseline", "HA", "HB"] }, "description": "baseline=-10dBm, HA=0dBm colored, HB=0dBm colorless" },
        "add_drop":       { "type": "array", "items": { "type": "string", "enum": ["colored", "colorless"] } },
        "grid_GHz":       { "type": "array", "items": { "type": "number" }, "description": "e.g. [75] or [100] or [75, 100]" }
      },
      "additionalProperties": false
    },

    "cross_standard_ref": {
      "description": "Pointer to the equivalent parameter in another standard. Enables cross-examination at query time.",
      "type": "object",
      "required": ["standard_id", "clause"],
      "properties": {
        "standard_id":      { "type": "string", "examples": ["OIF-400ZR-01.0", "ITU-T-G.709", "SFF-8024", "IEEE-802.3", "CMIS-5.0", "OIF-C-CMIS"] },
        "clause":           { "type": "string", "description": "Table, section, or figure reference in the external standard" },
        "param_name":       { "type": "string", "description": "Exact name used in the external standard for this parameter" },
        "relationship":     { "type": "string", "enum": ["equivalent", "subset", "superset", "references", "conflicts", "informs"], "default": "equivalent" },
        "delta_notes":      { "type": "string", "description": "Human-readable note on any differences, additions, or tighter/looser limits vs. OpenZR+" }
      },
      "additionalProperties": false
    },

    "test_conditions": {
      "description": "Conditions under which the limit applies. Missing fields mean 'all values of that dimension'.",
      "type": "object",
      "properties": {
        "temperature":      { "type": "string", "enum": ["operating_range", "25C_nominal", "cold_start", "max_operating"], "description": "Operating temperature condition" },
        "channel":          { "type": "string", "enum": ["all", "worst_case_channel", "center_channel"], "default": "all" },
        "baud_state":       { "type": "string", "enum": ["any", "steady_state", "during_training"] },
        "fec_state":        { "type": "string", "enum": ["any", "enabled", "disabled"] },
        "launch_condition": { "type": "string", "enum": ["any", "back_to_back", "with_fiber"] },
        "notes":            { "type": "string", "description": "Any additional condition not covered by structured fields" }
      },
      "additionalProperties": false
    },

    "numeric_param": {
      "description": "A single measurable parameter with limit, unit, scope, and traceability.",
      "type": "object",
      "required": ["id", "name", "category", "applies_to", "unit", "reference"],
      "properties": {
        "id":               { "type": "string", "description": "Dot-notation ID: <category>.<section>.<sequence>, e.g. opt.tx.11.2.100" },
        "name":             { "type": "string", "description": "Canonical parameter name as used in OpenZR+" },
        "aliases":          { "type": "array",  "items": { "type": "string" }, "description": "Alternative names found in vendor datasheets or other standards. Used by the normalizer." },
        "category":         { "type": "string", "enum": ["dwdm_link", "tx_optical", "rx_optical", "frame_budget", "dsp", "filter", "noise_mask", "spectral_mask"] },
        "applies_to":       { "$ref": "#/definitions/applies_to_filter" },
        "min":              { "type": ["number", "null"], "description": "Minimum allowed value, null if no lower bound" },
        "max":              { "type": ["number", "null"], "description": "Maximum allowed value, null if no upper bound" },
        "typical":          { "type": ["number", "null"] },
        "unit":             { "type": "string", "examples": ["dBm", "THz", "GHz", "GBd", "ps/nm", "dB", "dB/0.1nm"] },
        "unit_aliases":     { "type": "array",  "items": { "type": "string" }, "description": "Equivalent units seen in vendor datasheets, e.g. ['mW'] for dBm" },
        "unit_scale_to_si": { "type": "number",  "description": "Multiply this param's value by this to get SI base unit. e.g. 1e12 for THz→Hz" },
        "test_conditions":  { "$ref": "#/definitions/test_conditions" },
        "severity":         { "type": "string", "enum": ["mandatory", "conditional", "recommended", "informative"], "description": "mandatory=SHALL, conditional=SHALL WHEN, recommended=SHOULD, informative=MAY" },
        "check_type":       { "type": "string", "enum": ["range", "min_only", "max_only", "exact", "mask", "enum_match", "cross_param"], "description": "How the compliance engine should evaluate this parameter" },
        "conditional_on":   { "type": ["string", "null"], "description": "ID of another parameter this limit depends on. Null if unconditional." },
        "footnotes":        { "type": "array",  "items": { "type": "string" }, "description": "Verbatim footnotes from the standard table that modify this limit" },
        "reference":        { "type": "string", "description": "Section/table reference in OpenZR+ Rev3, e.g. 'Table 11-2, §11.2'" },
        "cross_standard_refs": { "type": "array", "items": { "$ref": "#/definitions/cross_standard_ref" } },
        "extraction_confidence": { "type": "string", "enum": ["high", "medium", "low", "manual"], "description": "Set by extraction pipeline. 'manual' = human-verified." },
        "extraction_notes": { "type": "string", "description": "Ambiguities flagged during LLM extraction. Human reviewer notes." }
      },
      "additionalProperties": false
    },

    "mask_point": {
      "type": "object",
      "required": ["freq_offset_GHz", "limit_dBc"],
      "properties": {
        "freq_offset_GHz": { "type": "number" },
        "limit_dBc":       { "type": "number" }
      }
    },

    "mask_profile": {
      "description": "Frequency-domain mask (spectral or noise). Cannot be flattened to min/max — stored as breakpoint arrays.",
      "type": "object",
      "required": ["mask_id", "mask_type", "applies_to", "reference", "points"],
      "properties": {
        "mask_id":      { "type": "string" },
        "mask_type":    { "type": "string", "enum": ["tx_spectral", "laser_freq_noise", "tx_clock_phase_noise"] },
        "applies_to":   { "$ref": "#/definitions/applies_to_filter" },
        "x_axis_unit":  { "type": "string", "default": "GHz" },
        "y_axis_unit":  { "type": "string", "default": "dBc" },
        "reference":    { "type": "string" },
        "points":       { "type": "array", "items": { "$ref": "#/definitions/mask_point" }, "minItems": 2 },
        "cross_standard_refs": { "type": "array", "items": { "$ref": "#/definitions/cross_standard_ref" } }
      },
      "additionalProperties": false
    },

    "compliance_rule": {
      "description": "A structured compliance rule. predicate_type tells the engine which checker to invoke.",
      "type": "object",
      "required": ["rule_id", "group", "predicate_type", "severity", "reference"],
      "properties": {
        "rule_id":          { "type": "string", "description": "e.g. R1.1, R11.2.3" },
        "group":            { "type": "string", "enum": ["format_identification", "line_encoding", "framing", "gmp_mapping", "ofec", "dsp_framing", "tx_optical", "rx_optical", "dwdm_link", "client_interface", "interoperability"] },
        "statement":        { "type": "string", "description": "Human-readable rule statement, verbatim or close paraphrase from the standard" },
        "predicate_type":   { "type": "string", "enum": ["numeric_range", "numeric_tolerance", "enum_match", "bitmask_match", "cross_param_ratio", "table_lookup", "prose_rag"], "description": "numeric_range/tolerance/enum → deterministic checker. prose_rag → LLM over standard PDF." },
        "parameter_ref":    { "type": ["string", "null"], "description": "ID from numeric_param.id this rule checks. Null for prose_rag rules." },
        "expected_value":   { "description": "For enum_match or exact checks", "type": ["string", "number", "null"] },
        "tolerance":        { "type": ["number", "null"], "description": "For numeric_tolerance checks, e.g. 20 for ±20ppm" },
        "tolerance_unit":   { "type": ["string", "null"], "examples": ["ppm", "dB", "percent"] },
        "applies_to":       { "$ref": "#/definitions/applies_to_filter" },
        "severity":         { "type": "string", "enum": ["mandatory", "conditional", "recommended", "informative"] },
        "conditional_on":   { "type": ["string", "null"] },
        "reference":        { "type": "string" },
        "cross_standard_refs": { "type": "array", "items": { "$ref": "#/definitions/cross_standard_ref" } },
        "rag_fallback":     { "type": "boolean", "default": false, "description": "If true, even deterministic rules should be validated against PDF via RAG as a secondary check" },
        "extraction_confidence": { "type": "string", "enum": ["high", "medium", "low", "manual"] }
      },
      "additionalProperties": false
    }

  },

  "properties": {

    "$schema": { "type": "string" },

    "meta": {
      "type": "object",
      "required": ["standard_name", "version", "revision_date", "source_url", "dataset_version", "extraction_status"],
      "properties": {
        "standard_name":      { "type": "string", "const": "OpenZR+ MSA Technical Specification" },
        "version":            { "type": "string", "const": "3.0" },
        "revision_date":      { "type": "string", "format": "date", "const": "2023-07-28" },
        "source_url":         { "type": "string", "format": "uri" },
        "publisher":          { "type": "string", "const": "OpenZR+ MSA" },
        "dataset_version":    { "type": "string", "description": "Semver of this JSON dataset, independent of the standard version" },
        "extraction_status":  { "type": "string", "enum": ["draft", "llm_extracted", "human_verified", "frozen"], "description": "frozen = ground truth, use for runtime compliance checks" },
        "extracted_by":       { "type": "string" },
        "verified_by":        { "type": "string" },
        "last_updated":       { "type": "string", "format": "date" },
        "changelog":          { "type": "array", "items": { "type": "object", "properties": { "date": { "type": "string" }, "change": { "type": "string" } } } },
        "related_standards":  {
          "type": "array",
          "description": "All standards referenced by or relevant to OpenZR+",
          "items": {
            "type": "object",
            "required": ["standard_id", "name", "relationship"],
            "properties": {
              "standard_id":    { "type": "string" },
              "name":           { "type": "string" },
              "version":        { "type": "string" },
              "relationship":   { "type": "string", "enum": ["normative_reference", "informative_reference", "peer_standard", "superset", "subset"] },
              "notes":          { "type": "string" }
            }
          }
        }
      },
      "additionalProperties": false
    },

    "identity": {
      "description": "One entry per media_interface_id. Merges Tables 1-2a, 1-3, 1-4a.",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["media_interface_id", "format", "payload_rate_G", "framing_format", "modulation", "power_class", "add_drop_type"],
        "properties": {
          "media_interface_id":   { "type": "string", "examples": ["ZR400-OFEC-16QAM", "ZR400-OFEC-16QAM-HA", "ZR400-OFEC-8QAM-HB"] },
          "format":               { "type": "string", "enum": ["400ZR+", "300ZR+", "200ZR+", "100ZR+"] },
          "sff8024_id_decimal":   { "type": ["integer", "null"] },
          "sff8024_id_hex":       { "type": ["string", "null"], "examples": ["46h", "47h", "TBD"] },
          "payload_rate_G":       { "type": "number" },
          "application_bit_rate_Gbs": { "type": "number", "description": "Wire rate including FEC overhead, e.g. 481.108374" },
          "framing_format":       { "type": "string", "enum": ["ZR400-OFEC-16QAM", "ZR400-OFEC-8QAM", "ZR300-OFEC-8QAM", "ZR200-OFEC-QPSK", "ZR100-OFEC-QPSK"] },
          "symbol_rate_GBd":      { "type": "number" },
          "modulation":           { "type": "string", "enum": ["DP-16QAM", "DP-8QAM", "DP-QPSK"] },
          "bits_per_ui":          { "type": "integer" },
          "lane_count":           { "type": "integer", "const": 1 },
          "power_class":          { "type": "string", "enum": ["baseline", "HA", "HB"] },
          "min_tx_power_dBm":     { "type": "number" },
          "add_drop_type":        { "type": "string", "enum": ["colored", "colorless"] },
          "supported_host_interfaces": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "host_interface":  { "type": "string", "examples": ["1x400GBASE-R", "2x200GBASE-R", "4x100GBASE-R"] },
                "lane_count":      { "type": "integer" },
                "tributary_slots": { "type": "integer" }
              }
            }
          },
          "ncg_dB":               { "type": "number", "description": "Net Coding Gain in dB" },
          "pre_fec_ber":          { "type": "number", "description": "e.g. 2.0e-2" },
          "reference_standard":   { "type": "string", "examples": ["OpenZR+", "OIF-400ZR-01.0"] },
          "reference":            { "type": "string", "description": "Table reference in OpenZR+ Rev3" },
          "cross_standard_refs":  { "type": "array", "items": { "$ref": "#/definitions/cross_standard_ref" } }
        },
        "additionalProperties": false
      }
    },

    "line_encoding": {
      "description": "DSP framing, FEC, and modulation parameters per media_interface_id. §1, §7, §8.",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["media_interface_id", "modulation", "symbol_rate_GBd", "symbol_rate_tolerance_ppm", "fec"],
        "properties": {
          "media_interface_id":          { "type": "string" },
          "modulation":                  { "type": "string", "enum": ["DP-16QAM", "DP-8QAM", "DP-QPSK"] },
          "encoding":                    { "type": "string", "enum": ["absolute", "differential"], "const": "absolute" },
          "symbol_rate_GBd":             { "type": "number" },
          "symbol_rate_tolerance_ppm":   { "type": "number" },
          "bits_per_symbol":             { "type": "integer" },
          "fec": {
            "type": "object",
            "properties": {
              "type":         { "type": "string", "const": "OFEC" },
              "ncg_dB":       { "type": "number" },
              "pre_fec_ber":  { "type": "number" },
              "codec_ref":    { "type": "string", "description": "Section reference for codec definition, e.g. §7.1" }
            }
          },
          "dsp_super_frame_ref":   { "type": "string", "description": "Section reference, e.g. §9.1" },
          "pilot_sequence_ref":    { "type": "string", "description": "Section reference, e.g. §9.5" },
          "cross_standard_refs":   { "type": "array", "items": { "$ref": "#/definitions/cross_standard_ref" } }
        },
        "additionalProperties": false
      }
    },

    "framing": {
      "description": "ZR frame structure parameters per server mode (ZR100/200/300/400). §3, §5, §6.",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["frame_format", "rows", "columns", "oh_257b_blocks", "payload_257b_blocks_per_frame"],
        "properties": {
          "frame_format":                     { "type": "string", "enum": ["ZR100", "ZR200", "ZR300", "ZR400"] },
          "rows":                             { "type": "integer" },
          "columns":                          { "type": "integer" },
          "bits_per_row":                     { "type": "integer" },
          "block_size_bits":                  { "type": "integer", "const": 257 },
          "oh_257b_blocks":                   { "type": "integer", "description": "257-bit blocks allocated to AM/PAD/OH in row 1" },
          "payload_257b_blocks_per_frame":    { "type": "integer" },
          "payload_257b_blocks_per_4frames":  { "type": "integer", "description": "GMP is performed across 4 consecutive frames" },
          "multiframe_depth":                 { "type": "integer", "description": "Frames per multi-frame, e.g. 16 for ZR400" },
          "am_lanes":                         { "type": "integer", "description": "Alignment marker lanes" },
          "oh_blocks_count":                  { "type": "integer", "description": "Number of 320-bit OH blocks" },
          "pad_bits":                         { "type": "integer", "description": "Additional PAD bits between OH and payload" },
          "msi_byte_location":                { "type": "string", "description": "e.g. row 4, byte 5" },
          "gmp_stuffing_granularity_bits":    { "type": "integer", "const": 257 },
          "reference":                        { "type": "string" },
          "cross_standard_refs":              { "type": "array", "items": { "$ref": "#/definitions/cross_standard_ref" } }
        },
        "additionalProperties": false
      }
    },

    "optical_specs": {
      "description": "All optical parameters from §11. Sub-divided by measurement plane.",
      "type": "object",
      "required": ["dwdm_link", "tx_optical", "rx_optical", "mask_profiles"],
      "properties": {
        "dwdm_link":     { "type": "array", "items": { "$ref": "#/definitions/numeric_param" }, "description": "§11.1 Table 11-1: channel frequency, spacing, grid parameters" },
        "tx_optical":    { "type": "array", "items": { "$ref": "#/definitions/numeric_param" }, "description": "§11.2 Tables 11-2/11-2a: Tx output power, OSNR, linewidth, frequency error, SMSR, etc." },
        "rx_optical":    { "type": "array", "items": { "$ref": "#/definitions/numeric_param" }, "description": "§11.3 Table 11-3: Rx input power, OSNR tolerance, sensitivity, DGD, PDL, etc." },
        "mask_profiles": { "type": "array", "items": { "$ref": "#/definitions/mask_profile" }, "description": "§11.2.1, §11.2.2, §11.4.10, §11.4.11: frequency-domain masks (cannot be min/max scalars)" }
      },
      "additionalProperties": false
    },

    "client_interfaces": {
      "description": "Host-side interface definitions. §12 (informative). Links to IEEE 802.3 and CMIS.",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["interface_type", "rate_G", "lane_count", "informative_only"],
        "properties": {
          "interface_type":     { "type": "string", "examples": ["400GBASE-R", "200GBASE-R", "100GBASE-R"] },
          "rate_G":             { "type": "number" },
          "lane_count":         { "type": "integer" },
          "pcs_type":           { "type": "string", "examples": ["RS(544,514)", "RS(528,514)"] },
          "am_period_bits":     { "type": "integer" },
          "informative_only":   { "type": "boolean", "const": true },
          "supported_by_formats": { "type": "array", "items": { "type": "string" } },
          "reference":          { "type": "string" },
          "cross_standard_refs": { "type": "array", "items": { "$ref": "#/definitions/cross_standard_ref" } }
        },
        "additionalProperties": false
      }
    },

    "compliance_rules": {
      "description": "Structured compliance rules derived from all sections. predicate_type routes to the correct checker.",
      "type": "array",
      "items": { "$ref": "#/definitions/compliance_rule" }
    }

  }
}
